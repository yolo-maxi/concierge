# --- Venice (OpenAI-compatible) ---
VENICE_API_KEY=your_venice_key_here
VENICE_BASE_URL=https://api.venice.ai/api/v1
VENICE_MODEL=deepseek-v4-flash

# --- Page brief(s): pick ONE ---
# Single page:
CONCIERGE_BRIEF=./brief.example.json
# Multi page (keyed by pageId):
# CONCIERGE_BRIEFS=./briefs.json

# --- Conversation logging (all optional; each sink no-ops if unset) ---
# Enable any combination. Each completed turn is sent to every configured sink.

# 1) Webhook — POST the turn as JSON to your own backend (the simple option).
#    Payload: { type, at, brand, pageId, pageUrl, sessionId, emoji, question, answer, ip }
# CONCIERGE_WEBHOOK_URL=https://your-backend.example.com/concierge
# CONCIERGE_WEBHOOK_SECRET=             # sent as: Authorization: Bearer <secret>

# 2) Console — write one JSON line per turn to stdout (pipe it anywhere).
# CONCIERGE_LOG_CONSOLE=1

# 3) Telegram — formatted message to a chat (and optional forum topic).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# TELEGRAM_THREAD_ID=

# --- Server ---
PORT=8787
# Comma-separated allowed origins; omit for permissive (dev only)
ALLOWED_ORIGINS=
RATE_LIMIT=20
